  "category_2_rohs_compliance": {
    "description": "第二类：RoHS合规性检验",
    "2.1": {
      "name": "RoHS 2.0测试报告来源",
      "standard": "必须包含RoHS 2.0测试报告，接受第三方检测报告（CTI华测、SGS、BV、Intertek、TUV等）"
    },
    "2.2": {
      "name": "RoHS调查表日期有效性",
      "standard": "报告日期距检验日≤365天",
      "handler": "过期需重新提供"
    },
    "2.3": {
      "name": "RoHS调查表红框必填字段（6个）",
      "fields": [
        "Monomer（单体）",
        "Supplier（供应商）",
        "Control method（控制方法）",
        "Number（编号）",
        "Effective date of report（出报告日期）",
        "Remarks（备注）"
      ],
      "rule": "任何一项为空均视为不合格"
    },
    "2.4": {
      "name": "RoHS测试报告日期有效性",
      "standard": "报告日期距检验日≤365天"
    }
  },
  "category_3_cpk_compliance": {
    "description": "第三类：CPK合规性检验",
    "3.1": {
      "name": "CPK值要求",
      "standard": "关键尺寸CPK必须≥1.33",
      "calculation": "CPK = min(CPKu, CPKl)",
      "handler": "CPK<1.33需改善制程能力"
    },
    "3.2": {
      "name": "CPK报告与图纸/全尺寸报告对应性",
      "standard": "CPK报告尺寸必须与规格图纸、全尺寸量测报告中的尺寸标称值和公差范围完全一致"
    }
  },
  "category_4_dimension_correspondence": {
    "description": "第四类：尺寸公差对应性检验（包含关系）",
    "inclusion_relation": "C ⊆ B ⊆ A（CPK报告 ⊆ 全尺寸量测报告 ⊆ 规格图纸）",
    "4.1": {
      "name": "三文件尺寸及公差对应性",
      "method": "从三份文件分别提取尺寸集合A/B/C，验证C⊆B⊆A"
    }
  },
  "category_5_report_timeliness": {
    "description": "第五类：报告时效性检验",
    "5.1": {
      "name": "RoHS报告日期",
      "standard": "报告日期距检验日≤365天",
      "handler": "要求重新提供有效报告"
    },
    "5.2": {
      "name": "REACH报告日期",
      "standard": "报告日期距检验日≤365天",
      "handler": "要求重新提供有效报告"
    }
  },
  "category_6_conclusion": {
    "description": "第六类：检验结论与处理建议",
    "pass_template": "该封样报告符合XC-R-0802-DQM-002模板要求，建议通过审核。",
    "fail_template": "该封样报告存在以下问题，请供应商补充/修正后重新提交："
