      "cover": "含'Provisional Sample acknowledgement'或'临时样品承认书'封面",
      "engineering_drawing": "含尺寸标注+图号（如NC-XC260522-007）",
      "bom": "含'BOM'或'物料清单'表格",
      "sample_photo": "含'附上样品实物'",
      "cpk": "含'CPK'或'Cpk'表格",
      "rohs": "含'RoHS'调查表（含红框字段）",
      "reach": "含'REACH'调查表"
    }
  },
  "audit_workflow": {
    "steps": [
      "第零步：判定物料类型（电子料/结构件）",
      "第一步：文件类型检查（XC-R-0802-DQM-001 vs XC-R-0802-DQM-002）",
      "第二步：PDF结构分析（逐页分析内容类型）",
      "第三步：文件完整性检验（按物料类型区分16项/15项）",
      "第四步：RoHS合规性检验（4子项）",
      "第五步：CPK合规性检验（2子项）",
      "第六步：尺寸公差对应性检验（包含关系验证）",
      "第七步：报告时效性检验（RoHS/REACH日期）",
      "第八步：生成检验报告（Excel格式，8个工作表）"
    ]
  }
